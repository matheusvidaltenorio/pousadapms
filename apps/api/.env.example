# Copie para .env: cp .env.example .env
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pousada_pms?schema=public"

# Supabase: use DATABASE_URL (porta 6543) para a aplicação e DIRECT_URL (porta 5432) para migrate/seed.
# Se não usar Supabase pooler, coloque DIRECT_URL = DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/pousada_pms?schema=public"

PORT=3000
NODE_ENV=development
JWT_SECRET="dev-secret-change-in-production"
JWT_EXPIRES_IN="24h"
